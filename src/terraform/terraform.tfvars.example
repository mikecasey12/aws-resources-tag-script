# Copy this file to terraform.tfvars and fill in your actual values.
# terraform.tfvars is gitignored to prevent committing sensitive information.

# ARN of your existing ECS cluster (Fargate-compatible)
cluster_arn = "arn:aws:ecs:REGION:ACCOUNT_ID:cluster/CLUSTER_NAME"

# AWS region where resources will be created
aws_region = "us-east-1"

# Full URI of your Docker image in ECR
# Format: ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/REPO_NAME:TAG
container_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/tag-script:latest"

###############################################################################
# Network Configuration
###############################################################################

# ---------------------------------------------------------------------------
# VPC  (required — Terraform will prompt if not set here)
# ---------------------------------------------------------------------------
# Set to a specific VPC ID to use an existing VPC.
# Set to "" (empty string) to use the account's default VPC, or let Terraform
# create a new one if no default VPC exists.
#
# Not sure which VPC to use?  Leave this file as-is, run `terraform apply`,
# answer the prompt with "", then run `terraform output available_vpcs` to see
# all VPCs in the region.  Update this file and re-apply with the correct ID.
#
vpc_id = "vpc-xxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# Subnets  (required — Terraform will prompt if not set here)
# ---------------------------------------------------------------------------
# Set to a list of existing subnet IDs (recommended: 2+ in different AZs).
# Set to [] to let Terraform auto-discover previously-created subnets or create
# new ones inside the resolved VPC.
#
# After setting vpc_id above, run `terraform output available_subnets` to see
# all subnets in that VPC, then update this list accordingly.
#
private_subnets = [
  "subnet-xxxxxxxxxxxxxxxxx",
  "subnet-xxxxxxxxxxxxxxxxx",
]

# Number of subnets to create when private_subnets = [] and none are found (default: 2):
# subnet_count = 2

# ---------------------------------------------------------------------------
# ECS Security Group  (optional)
# ---------------------------------------------------------------------------
# Set to an existing security group ID to use it as-is.
# Leave unset or set to "" and Terraform will reuse the security group it
# previously created (matched by tag) or create a new one.
#
# ecs_sg_id = "sg-xxxxxxxxxxxxxxxxx"
